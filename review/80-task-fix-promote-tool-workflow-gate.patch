+                        if res.returncode != 0:
+                            if os.path.exists(dst):
+                                if os.path.isdir(dst): shutil.rmtree(dst)
+                                else: os.remove(dst)
+                            shutil.move(src, dst)
+                    else:
+                        if os.path.exists(dst):
+                            if os.path.isdir(dst): shutil.rmtree(dst)
+                            else: os.remove(dst)
+                        shutil.move(src, dst)
+                
+                # Commit migration if in git
+                if os.path.exists(os.path.join(self.tasks_path, ".git")):
+                    self._run_git(["add", "--all"], cwd=self.tasks_path)
